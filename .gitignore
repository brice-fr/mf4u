# ── Node / SvelteKit ──────────────────────────────────────────────────────
.DS_Store
node_modules/
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Rust / Tauri ──────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/android/
src-tauri/gen/apple/

# Built sidecar binaries (produced by PyInstaller in CI or local dev).
# Ignore compiled executables but always track the dev-mode shell script
# wrappers so a local PyInstaller run can never silently overwrite them.
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
!src-tauri/binaries/mf4u_sidecar-aarch64-apple-darwin
!src-tauri/binaries/mf4u_sidecar-x86_64-apple-darwin
!src-tauri/binaries/mf4u_sidecar-universal-apple-darwin

# ── Python sidecar ────────────────────────────────────────────────────────
sidecar/__pycache__/
sidecar/**/__pycache__/
sidecar/**/*.pyc
sidecar/*.pyc
sidecar/dist/
sidecar/build/
sidecar/*.spec

# ── OS artefacts ─────────────────────────────────────────────────────────
Thumbs.db
